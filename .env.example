# SmartOps configuration
APP_NAME=SmartOps Agent
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=120
LLM_MODEL_A=llama3.2:3b
LLM_MODEL_B=mistral:7b
# Fallback when Ollama is unavailable (deterministic mock for CI/demo)
LLM_FALLBACK_MODE=true

# RAG
RAG_PERSIST_DIR=./data/chroma
KNOWLEDGE_BASE_DIR=./knowledge_base
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RAG_FORCE_REINGEST=false

# RL (Epsilon-Greedy Contextual Bandit)
RL_EPSILON=0.15
RL_EPSILON_DECAY=0.995
RL_EPSILON_MIN=0.05
RL_STATE_PATH=./data/rl_bandit_state.json
RL_FEEDBACK_TIMEOUT_SECONDS=300
# Clip latency penalty so slow local LLMs don't dominate helpfulness
RL_LATENCY_CAP_SECONDS=10
TRANSACTION_STATE_PATH=./data/transactions.json
AUDIT_LOG_PATH=./data/audit.jsonl
# Optional Postgres audit (falls back to JSONL when unset / unavailable)
DATABASE_URL=

# Agent + async job queue
AGENT_MAX_STEPS=3
WARMUP_ON_STARTUP=true
JOB_WORKERS=2
JOB_QUEUE_MAX=1000

# Production
CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=60
REQUEST_ID_HEADER=X-Request-ID
# Only enable when behind a trusted reverse proxy (prevents XFF spoofing)
TRUST_PROXY_HEADERS=false
# Empty disables auth (local/CI). Required + strong when APP_ENV=production.
API_KEY=
# Optional distinct admin key for /rl/state and /metrics (else API_KEY is admin)
ADMIN_API_KEY=
# Optional Redis for shared rate limiting + bandit CAS sync
REDIS_URL=

# Optional OpenTelemetry (soft-imported; install separately if needed)
# pip install -r requirements-otel.txt
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=smartops-agent
